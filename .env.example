# Active Environment: dev | sit | preprod
ENV=dev

# Environment URLs
DEV_URL=https://dev.csms.statiq.in/
SIT_URL=https://sit.csms.statiq.in/
PREPROD_URL=https://preprod.csms.statiq.co.in/

# Credentials
LOGIN_NUMBER=your_login_number
PASSWORD=your_password

# Redis Credentials - Dev
DEV_REDIS_HOST=localhost
DEV_REDIS_PORT=6379
DEV_REDIS_PASSWORD=
DEV_REDIS_DB=0
DEV_REDIS_SSL=false

# Redis Credentials - SIT
SIT_REDIS_HOST=sit-redis-placeholder
SIT_REDIS_PORT=6379
SIT_REDIS_PASSWORD=
SIT_REDIS_DB=0
SIT_REDIS_SSL=true

# Redis Credentials - Pre-Prod
PREPROD_REDIS_HOST=preprod-redis-placeholder
PREPROD_REDIS_PORT=6379
PREPROD_REDIS_PASSWORD=
PREPROD_REDIS_DB=0
PREPROD_REDIS_SSL=true

